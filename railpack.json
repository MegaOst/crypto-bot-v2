{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "gunicorn --bind 0.0.0.0:$PORT --workers 1 --timeout 120 web.app:app"
  }
}
